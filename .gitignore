# ── macOS ────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Obsidian ─────────────────────────────────────────────────
.obsidian/

# ── 環境變數 / API Keys（絕對不能進版控）────────────────────
dashboard/.env
.env
*.env

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/

# ── uv 虛擬環境（不進版控，用 uv sync 重建）────────────────
.venv/

# ── uv 快取（本機快取，不需版控）────────────────────────────
.uv/

# ── Streamlit ────────────────────────────────────────────────
.streamlit/

# ── 原始資料附件（圖片，體積較大）──────────────────────────
# 排除附件內容，但保留資料夾本身（.gitkeep 佔位）
raw/assets/*
!raw/assets/.gitkeep

# ── 原始 PDF（體積大的二進位檔案，建議改用 Git LFS 管理）──
# 若要追蹤 PDF，請移除下一行或改用：git lfs track "*.pdf"
raw/*.pdf
